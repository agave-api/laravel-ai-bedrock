{
  "name": "agave-api/laravel-ai-bedrock",
  "description": "AWS Bedrock provider for the Laravel AI SDK",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Agave API"
    }
  ],
  "require": {
    "php": "^8.3",
    "laravel/ai": "^0.3",
    "clinically/prism-bedrock": "^0.1"
  },
  "require-dev": {
    "orchestra/testbench": "^10.0",
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "AgaveApi\\LaravelAiBedrock\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "AgaveApi\\LaravelAiBedrock\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "AgaveApi\\LaravelAiBedrock\\BedrockServiceProvider"
      ]
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
