{
  "name": "agave-api/laravel-ai-bedrock",
  "description": "AWS Bedrock provider for the Laravel AI SDK",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Clinically"
    },
    {
      "name": "Agave API"
    }
  ],
  "require": {
    "php": "^8.3",
    "laravel/ai": "^0.4",
    "agave-api/prism-bedrock": "@dev"
  },
  "require-dev": {
    "orchestra/testbench": "^11.0",
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "AgaveApi\\LaravelAiBedrock\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "AgaveApi\\LaravelAiBedrock\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "AgaveApi\\LaravelAiBedrock\\BedrockServiceProvider"
      ]
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "repositories": {
    "local-prism-bedrock": {
      "type": "path",
      "url": "../prism-bedrock"
    }
  }
}
