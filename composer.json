{
  "name": "wojt-janowski/laravel-ai-bedrock",
  "description": "AWS Bedrock provider for the Laravel AI SDK",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Wojt Janowski"
    }
  ],
  "require": {
    "php": "^8.4",
    "laravel/ai": "^0.3",
    "prism-php/bedrock": "^1.8"
  },
  "require-dev": {
    "orchestra/testbench": "^10.0",
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "WojtJanowski\\LaravelAiBedrock\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "WojtJanowski\\LaravelAiBedrock\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "WojtJanowski\\LaravelAiBedrock\\BedrockServiceProvider"
      ]
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
